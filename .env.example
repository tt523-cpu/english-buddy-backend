# ============================================================
# English Buddy Backend - Environment Configuration
#
# Copy this file to .env and fill in your API keys.
# All AI credentials stay on the server — frontend never sees them.
#
# Quick Start:
#   cp .env.example .env
#   # Edit .env with your real keys
#   docker compose up -d
#   # Open http://your-server-ip:5000
# ============================================================

# --------------- LLM (AI Chat / Translation) ---------------
# DeepSeek (recommended: cheap, fast, good quality)
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat

# Other LLM options (uncomment to use):
#
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com
#   LLM_API_KEY=sk-your-openai-key
#   LLM_MODEL=gpt-4o-mini
#
# Kimi / Moonshot (Chinese-friendly):
#   LLM_BASE_URL=https://api.moonshot.cn
#   LLM_API_KEY=sk-your-kimi-key
#   LLM_MODEL=moonshot-v1-8k
#
# Zhipu / GLM:
#   LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   LLM_API_KEY=your-zhipu-key
#   LLM_MODEL=glm-4-flash
#
# Local Ollama (no key needed, use Docker host IP):
#   LLM_BASE_URL=http://host.docker.internal:11434
#   LLM_API_KEY=
#   LLM_MODEL=llama3.2:latest

# --------------- STT (Speech-to-Text) ---------------
# Groq Whisper (FREE, recommended)
STT_BASE_URL=https://api.groq.com/openai/v1
STT_API_KEY=gsk-your-groq-api-key
STT_MODEL=whisper-large-v3
STT_TRANSCRIBE_PATH=/audio/transcriptions
STT_HEALTH_PATH=/models

# Other STT options (uncomment to use):
#
# OpenAI Whisper:
#   STT_BASE_URL=https://api.openai.com/v1
#   STT_API_KEY=sk-your-openai-key
#   STT_MODEL=whisper-1
#   STT_TRANSCRIBE_PATH=/audio/transcriptions
#   STT_HEALTH_PATH=/models
#
# SiliconFlow (Chinese service, 100 free calls/day):
#   STT_BASE_URL=https://api.siliconflow.cn/v1
#   STT_API_KEY=sk-your-siliconflow-key
#   STT_MODEL=FunAudioLLM/SenseVoiceSmall
#   STT_TRANSCRIBE_PATH=/audio/transcriptions
#   STT_HEALTH_PATH=/models
#
# Local Faster Whisper (no key needed):
#   STT_BASE_URL=http://host.docker.internal:18000
#   STT_API_KEY=
#   STT_MODEL=
#   STT_TRANSCRIBE_PATH=/transcribe
#   STT_HEALTH_PATH=/health

# --------------- Server ---------------
HOST=0.0.0.0
PORT=5000
DEBUG=false
